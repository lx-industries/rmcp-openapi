FROM ubuntu:noble@sha256:786a8b558f7be160c6c8c4a54f9a57274f3b4fb1491cf65146521ae77ff1dc54

COPY rmcp-openapi-server /usr/bin

# ca-certificates is needed for HTTPS calls (reqwest+rustls uses native roots)
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

ENV RMCP_OPENAPI_LOG=info

EXPOSE 8080

ENTRYPOINT [ "rmcp-openapi-server" ]
